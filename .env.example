# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Server-only Supabase settings
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=ai-images

# Server-only image generation API settings
IMAGE_API_BASE_URL=https://api.kie.ai
IMAGE_API_KEY=your-image-api-key
# Shared Tokendance gateway settings for ERNIE Image and the Canvas Pi Agent
TOKENDANCE_API_BASE_URL=https://tokendance.space/gateway/v1
TOKENDANCE_API_KEY=your-tokendance-api-key
PI_AGENT_MODEL=deepseek-v4-flash
# Legacy ERNIE settings remain supported as a fallback
ERNIE_IMAGE_API_BASE_URL=https://tokendance.space/gateway/v1
ERNIE_IMAGE_API_KEY=your-ernie-image-api-key
APP_URL=http://localhost:3000

# Kie AI webhook verification key
IMAGE_API_WEBHOOK_HMAC_KEY=your-webhook-hmac-key
